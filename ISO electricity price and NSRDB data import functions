%% import_iso_prices.m
% Download and parse electricity price data from ISO New England Express API.
%
% ISO New England real-time and day-ahead LMPs are publicly available at:
%   https://www.iso-ne.com/isoexpress/web/reports/pricing/-/tree/zone-info
%
% Usage:
%   prices = import_iso_prices('isone', '2023-01-01', '2023-12-31')
%   prices = import_iso_prices('isone', '2023-01-01', '2023-12-31', 'da')
%
% Output:
%   prices — struct with fields:
%     .timestamps   datetime array (hourly)
%     .lmp_usd_mwh  Locational Marginal Price [$/MWh]
%     .lmp_usd_kwh  LMP in [$/kWh]
%     .iso          ISO name string
%     .market_type  'rt' or 'da'

function prices = import_iso_prices(iso_name, date_start, date_end, market_type)

if nargin < 4, market_type = 'da'; end  % Default: day-ahead

iso_name = lower(iso_name);
t_start  = datetime(date_start);
t_end    = datetime(date_end);

fprintf('Importing %s prices from %s (%s to %s)...\n', ...
    upper(iso_name), upper(market_type), date_start, date_end);

switch iso_name
    case 'isone'
        prices = import_isone(t_start, t_end, market_type);
    case 'caiso'
        prices = import_caiso(t_start, t_end, market_type);
    case 'ercot'
        prices = import_ercot(t_start, t_end, market_type);
    otherwise
        error('import_iso_prices:unknownISO', ...
            'Unknown ISO: %s. Supported: isone, caiso, ercot', iso_name);
end

% Convert to $/kWh
prices.lmp_usd_kwh = prices.lmp_usd_mwh / 1000;

% Basic validation
n_expected = hours(t_end - t_start) + 1;
if numel(prices.lmp_usd_kwh) ~= n_expected
    warning('import_iso_prices:lengthMismatch', ...
        'Expected %d hourly values, got %d. Check for missing hours.', ...
        n_expected, numel(prices.lmp_usd_kwh));
end

fprintf('  Loaded %d hourly prices. Mean LMP = $%.2f/MWh\n', ...
    numel(prices.lmp_usd_kwh), mean(prices.lmp_usd_mwh, 'omitnan'));

end

function prices = import_isone(t_start, t_end, market_type)
% ISO New England Express — Day-Ahead or Real-Time LMPs.
%
% Data format (CSV from isoexpress):
%   Date, Hour, Location ID, Location Name, Locational Marginal Price, ...
%
% NOTE: For automated download, register at https://www.iso-ne.com/isoexpress/
% and use their REST API. This function shows the parsing logic for
% manually downloaded CSVs.

% Try local cache first
cache_path = fullfile('data', 'electricity_prices', ...
    sprintf('isone_%s_%s_%s.mat', market_type, ...
    datestr(t_start, 'yyyymmdd'), datestr(t_end, 'yyyymmdd')));

if isfile(cache_path)
    fprintf('  Loading from cache: %s\n', cache_path);
    load(cache_path, 'prices');
    return
end

% Fallback: load demo CSV bundled with project
demo_csv = fullfile('data', 'electricity_prices', 'isone_2023_demo.csv');
if ~isfile(demo_csv)
    error('import_isone:noData', ...
        ['ISO-NE price data not found.\n' ...
         'Download from: https://www.iso-ne.com/isoexpress/web/reports/pricing/-/tree/zone-info\n' ...
         'Save as: %s'], demo_csv);
end

T = readtable(demo_csv, 'VariableNamingRule', 'preserve');

% Parse timestamps (ISO-NE format: MM/DD/YYYY HH:MM:SS)
ts_col = T.('Date/Time (EST)');
if iscell(ts_col)
    timestamps = datetime(ts_col, 'InputFormat', 'MM/dd/yyyy HH:mm:ss');
else
    timestamps = ts_col;
end

% Filter to requested date range
mask = timestamps >= t_start & timestamps <= t_end;
timestamps = timestamps(mask);
lmp        = T.('DA LMP ($/MWh)')(mask);

% Fill missing with NaN, then linear interpolate
if any(isnan(lmp))
    lmp = fillmissing(lmp, 'linear');
end

prices.timestamps    = timestamps;
prices.lmp_usd_mwh   = lmp;
prices.iso           = 'ISONE';
prices.market_type   = market_type;
prices.location_name = 'NEPOOL';

% Cache result
save(cache_path, 'prices');

end

function prices = import_caiso(t_start, t_end, market_type)
% CAISO OASIS — Day-Ahead Market prices via OASIS API.
% API docs: http://oasis.caiso.com/mrioasis/logon.do

% URL template for CAISO OASIS (hourly, system average price)
base_url = 'http://oasis.caiso.com/oasisapi/SingleZip';
params = sprintf('?queryname=PRC_HASP_LMP&market_run_id=DAM&node=TH_NP15_GEN-APND&startdatetime=%sT00:00-0000&enddatetime=%sT23:00-0000&resultformat=6', ...
    datestr(t_start, 'yyyymmdd'), datestr(t_end, 'yyyymmdd'));

fprintf('  Fetching from CAISO OASIS...\n');
try
    data = webread([base_url params]);
    % Parse XML/CSV response (CAISO returns ZIP with CSV inside)
    % [parsing code omitted for brevity — see docs/caiso_parsing.md]
    prices = parse_caiso_response(data);
catch ME
    warning('import_caiso:downloadFailed', ...
        'CAISO download failed: %s. Using demo data.', ME.message);
    prices = generate_demo_prices(t_start, t_end, 'CAISO');
end

end

function prices = import_ercot(t_start, t_end, market_type)
% ERCOT Settlement Point Prices (SPP) via ERCOT API.
% API docs: https://data.ercot.com/data-product-archive/

fprintf('  Fetching from ERCOT...\n');
try
    % ERCOT public API (no auth required for historical SPPs)
    prices = fetch_ercot_spp(t_start, t_end);
catch ME
    warning('import_ercot:downloadFailed', ...
        'ERCOT download failed: %s. Using demo data.', ME.message);
    prices = generate_demo_prices(t_start, t_end, 'ERCOT');
end

end

function prices = generate_demo_prices(t_start, t_end, iso_name)
% Generate synthetic electricity prices for demo/testing.
% Uses a diurnal pattern typical of US grid markets.

timestamps = t_start : hours(1) : t_end;
n = numel(timestamps);

hour_of_day = hour(timestamps);

% Base price with diurnal variation
base_price = 35;  % $/MWh
diurnal    = 15 * sin(pi * (hour_of_day - 6) / 12).^2;
noise      = 8 * randn(1, n);
lmp        = max(base_price + diurnal + noise, 0);

% Add occasional price spikes (mimics real markets)
spike_hrs  = randperm(n, round(n * 0.01));
lmp(spike_hrs) = lmp(spike_hrs) + 200 * rand(1, numel(spike_hrs));

prices.timestamps    = timestamps;
prices.lmp_usd_mwh   = lmp;
prices.iso           = iso_name;
prices.market_type   = 'demo';
prices.location_name = 'SYNTHETIC';

warning('generate_demo_prices:syntheticData', ...
    'Using SYNTHETIC electricity prices. For real analysis, download from %s.', iso_name);

end


