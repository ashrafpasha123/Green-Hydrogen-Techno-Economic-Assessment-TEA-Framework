function station_data = import_nsrdb(lat, lon, year, api_key)
% import_nsrdb  Fetch hourly solar irradiance from NREL NSRDB via API.
%
%   station_data = import_nsrdb(lat, lon, year)
%   station_data = import_nsrdb(lat, lon, year, api_key)
%
%   Inputs:
%     lat      — Latitude [decimal degrees]
%     lon      — Longitude [decimal degrees]
%     year     — Year (e.g. 2022; NSRDB coverage 1998-2022)
%     api_key  — NREL API key (sign up free at https://developer.nrel.gov)
%
%   Output:
%     station_data — struct with fields:
%       .Latitude, .Longitude, .Elevation_m, .Timezone
%       .GHI       [W/m²] Global Horizontal Irradiance (8760x1)
%       .DHI       [W/m²] Diffuse Horizontal Irradiance
%       .DNI       [W/m²] Direct Normal Irradiance
%       .Temperature_C, .WindSpeed_ms, .Pressure_mbar
%       .Timestamps  datetime (8760x1, hourly)
%
%   Notes:
%     - Free API: 1000 requests/day per key
%     - NSRDB spatial resolution: 4km
%     - Data source: https://nsrdb.nrel.gov/

if nargin < 4
    api_key = getenv('NREL_API_KEY');
    if isempty(api_key)
        api_key = 'DEMO_KEY';  % Limited to 30 req/hr, 50 req/day
        warning('import_nsrdb:noAPIKey', ...
            ['Using DEMO_KEY (limited). Get free key at https://developer.nrel.gov\n' ...
             'Set environment variable NREL_API_KEY or pass key as 4th argument.']);
    end
end

% Check cache
cache_file = fullfile('data', 'nsrdb_cache', ...
    sprintf('nsrdb_%.4f_%.4f_%d.mat', lat, lon, year));
if isfile(cache_file)
    load(cache_file, 'station_data');
    fprintf('NSRDB: loaded from cache (%s)\n', cache_file);
    return
end

% NSRDB PSM v3 API endpoint
attributes = 'ghi,dhi,dni,air_temperature,wind_speed,surface_pressure';
url = sprintf(['https://developer.nrel.gov/api/nsrdb/v2/solar/psm3-download.csv?' ...
    'wkt=POINT(%.6f%%20%.6f)&names=%d&leap_day=false&interval=60&' ...
    'utc=false&full_name=MathWorks%%20User&email=user%%40example.com&' ...
    'affiliation=Research&mailing_list=false&reason=Research&' ...
    'attributes=%s&api_key=%s'], lon, lat, year, attributes, api_key);

fprintf('Fetching NSRDB data: lat=%.4f, lon=%.4f, year=%d ...\n', lat, lon, year);

try
    % Download CSV (first 2 rows are metadata, rest is hourly data)
    tmp = tempname;
    websave(tmp, url);
    raw = readlines(tmp);

    % Row 1: header metadata, Row 2: values, Row 3: column names, Row 4+: data
    meta_keys   = strsplit(raw{1}, ',');
    meta_vals   = strsplit(raw{2}, ',');
    col_names   = strsplit(raw{3}, ',');

    data_str = strjoin(raw(4:end), '\n');
    T = readtable(tmp, 'NumHeaderLines', 3, 'VariableNamingRule', 'preserve');

    % Parse metadata
    tz  = str2double(meta_vals{strcmp(meta_keys, 'Time Zone')});
    elev = str2double(meta_vals{strcmp(meta_keys, 'Elevation')});

    % Build timestamps (TMY: year doesn't matter, use 2001 non-leap)
    t0  = datetime(year, 1, 1, 0, 30, 0);  % Half-hour offset (midpoint)
    timestamps = t0 + hours(0:8759)';

    station_data.Latitude      = lat;
    station_data.Longitude     = lon;
    station_data.Elevation_m   = elev;
    station_data.Timezone      = tz;
    station_data.Year          = year;
    station_data.GHI           = T.GHI;
    station_data.DHI           = T.DHI;
    station_data.DNI           = T.DNI;
    station_data.Temperature_C = T.('Temperature');
    station_data.WindSpeed_ms  = T.('Wind Speed');
    station_data.Pressure_mbar = T.('Surface Pressure');
    station_data.Timestamps    = timestamps;

    % Cache for reuse
    if ~exist(fileparts(cache_file), 'dir')
        mkdir(fileparts(cache_file));
    end
    save(cache_file, 'station_data');
    fprintf('  Saved to cache: %s\n', cache_file);

catch ME
    warning('import_nsrdb:failed', 'NSRDB fetch failed: %s', ME.message);
    fprintf('  Generating synthetic irradiance profile for lat=%.2f...\n', lat);
    station_data = generate_synthetic_irradiance(lat, lon, year);
end

end

function sd = generate_synthetic_irradiance(lat, lon, year)
% Generate synthetic solar irradiance for demo/offline use.

n = 8760;
hours_vec = (0:n-1)';
doy = floor(hours_vec / 24) + 1;
hod = mod(hours_vec, 24);

% Solar declination (approximate)
declination = 23.45 * sind(360/365 * (doy - 81));

% Sunrise/sunset hours (approximate)
lat_r = lat * pi / 180;
decl_r = declination * pi / 180;
cos_ha = -tan(lat_r) * tan(decl_r);
cos_ha = clamp(cos_ha, -1, 1);
ha = acos(cos_ha) * 180 / pi;
sunrise = 12 - ha / 15;
sunset  = 12 + ha / 15;

% GHI: clear-sky model (simplified)
ghi_raw = zeros(n, 1);
daylight = hod >= sunrise & hod <= sunset;
solar_angle = max(0, ...
    sind(90 - abs(lat) + declination) .* ...
    cosd(15 * (hod - 12)));
ghi_clear = 900 * solar_angle;
ghi_raw(daylight) = ghi_clear(daylight);

% Add cloud variability (random daily factor)
cloud_factor = 0.6 + 0.4 * rand(365, 1);
cloud_hr = repelem(cloud_factor, 24);
ghi_raw = ghi_raw .* cloud_hr;

sd.Latitude      = lat;
sd.Longitude     = lon;
sd.Elevation_m   = 100;
sd.Timezone      = -5;
sd.Year          = year;
sd.GHI           = max(ghi_raw, 0);
sd.DHI           = sd.GHI * 0.15;
sd.DNI           = sd.GHI * 0.75;
sd.Temperature_C = 15 + 10 * sind(2*pi*(doy-80)/365) + 5*randn(n,1);
sd.WindSpeed_ms  = 4 + 2 * randn(n, 1);
sd.Pressure_mbar = 1013 * ones(n, 1);
sd.Timestamps    = datetime(year,1,1,0,0,0) + hours(0:n-1)';

warning('import_nsrdb:synthetic', ...
    'Using SYNTHETIC irradiance. Download real data from https://nsrdb.nrel.gov');

end

